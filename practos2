<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Персональный трекер расходов</title>
</head>
<body>
    <script>
        let expenses = [
            { id: 1, title: "Супермаркет", amount: 3500, category: "Продукты" },
            { id: 2, title: "Метро", amount: 1200, category: "Транспорт" },
            { id: 3, title: "Ресторан", amount: 2100, category: "Еда" },
            { id: 4, title: "Такси", amount: 600, category: "Транспорт" },
            { id: 5, title: "Аптека", amount: 850, category: "Здоровье" }
        ]
        let nextId = 6

        function addExpense(title, amount, category) {
            if (!title || title === "") {
                console.log("Ошибка: название не может быть пустым")
                return false
            }
            if (amount <= 0 || isNaN(amount)) {
                console.log("Ошибка: сумма должна быть положительным числом")
                return false
            }
            if (!category || category === "") {
                console.log("Ошибка: категория не может быть пустой")
                return false
            }
            
            expenses.push({ id: nextId++, title, amount: Number(amount), category })
            console.log(`Расход добавлен: "${title}" (${amount} руб.) в категории "${category}"`)
            return true
        }

        function printAllExpenses() {
            console.log("Все расходы")
            if (expenses.length === 0) {
                console.log("Расходов нет")
                return
            }
            
            console.log(" ID | Название | Сумма (руб) | Категория")
            
            expenses.forEach(e => {
                console.log(` ${e.id.toString().padEnd(3)}| ${e.title.padEnd(28).substring(0, 28)}| ${e.amount.toString().padStart(9)} | ${e.category.padEnd(16)}`)
            })
            
            let total = getTotalAmount(false)
            console.log(`     ИТОГО:                         ${total.toString().padStart(9)} руб.`)
        }

        function getTotalAmount(showCheck = true) {
            let total = expenses.reduce((sum, e) => sum + e.amount, 0)
            if (showCheck) {
                console.log("Чек")
                console.log(`Всего потрачено: ${total} рублей`)
            }
            return total
        }

        function getExpensesByCategory(category) {
            console.log(`Категория: "${category}"`)
            let result = expenses.filter(e => e.category.toLowerCase() === category.toLowerCase())
            
            if (result.length === 0) {
                console.log("Нет расходов в этой категории")
                return []
            }
            
            result.forEach((e, i) => console.log(`  ${i+1}. "${e.title}" - ${e.amount} руб.`))
            let total = result.reduce((sum, e) => sum + e.amount, 0)
            console.log(`Итого по категории: ${total} руб. (${result.length} операций)`)
            return result
        }

        function findExpenseByTitle(search) {
            console.log(`Поиск: "${search}"`)
            if (!search) {
                console.log("Строка не может быть пустой")
                return null
            }
            
            let found = expenses.filter(e => e.title.toLowerCase().includes(search.toLowerCase()))
            
            if (found.length === 0) {
                console.log(`Ничего не найдено по запросу: ${search}`)
                return false
            }
            
            found.forEach(e => {
                console.log("Найдено:")
                console.log(`  ID: ${e.id}\n  Название: "${e.title}"\n  Сумма: ${e.amount} руб.\n  Категория: ${e.category}`)
            })
            return true
        }

        function deleteExpenseById(id) {
            console.log(`Удаление (ID: ${id})`)
            let index = expenses.findIndex(e => e.id === id)
            if (index === -1) {
                console.log(`Расход с ID ${id} не найден`)
                return
            }
            console.log(`Удалён расход: "${expenses[index].title}" (ID: ${id})`)
            expenses.splice(index, 1)
        }

        function printCategoryStats() {
            console.log("Статистика по категориям")
            if (expenses.length === 0) {
                console.log("Нет данных для статистики")
                return
            }
            
            let categories = [...new Set(expenses.map(e => e.category))]
            let grandTotal = 0
            
            categories.forEach(cat => {
                let catExpenses = expenses.filter(e => e.category === cat)
                let total = catExpenses.reduce((sum, e) => sum + e.amount, 0)
                grandTotal += total
                let max = catExpenses.reduce((max, e) => e.amount > max.amount ? e : max, catExpenses[0])
                
                console.log(`${cat}:`)
                console.log(`     Операций: ${catExpenses.length}`)
                console.log(`     Сумма: ${total} руб.`)
                console.log(`     Средний чек: ${Math.round(total/catExpenses.length)} руб.`)
                console.log(`     Самая дорогая: "${max.title}" (${max.amount} руб.)`)
            })
            
            console.log("Общая статистика:")
            console.log(`     Всего операций: ${expenses.length}`)
            console.log(`     Всего потрачено: ${grandTotal} руб.`)
            console.log(`     Средний расход: ${Math.round(grandTotal/expenses.length)} руб.`)
        }

        let expenseTracker = {
            expenses,
            addExpense,
            getTotalAmount,
            getExpensesByCategory,
            findExpenseByTitle,
            deleteExpenseById,
            printCategoryStats,
            printAllExpenses
        }

        function getNumberFromPrompt(message) {
            let value = prompt(message)
            return value === null ? null : parseFloat(value)
        }

        function showNotificationMenu() {
            return prompt(
                "Персональный трекер расходов\n" +
                `Всего расходов: ${expenses.length}\n\n` +
                "1. Добавить новый расход\n" +
                "2. Показать все расходы\n" +
                "3. Показать общую сумму\n" +
                "4. Поиск по категории\n" +
                "5. Поиск по названию\n" +
                "6. Удалить расход по ID\n" +
                "7. Статистика по категориям\n" +
                "0. Выход\n\n" +
                "Введите номер действия (0-7):"
            )
        }

        function handleUserChoice(choice) {
            switch(choice) {
                case "1": {
                    let title = prompt("Введите название расхода:")
                    if (!title) { console.log("Название не может быть пустым"); return true }
                    
                    let amount = getNumberFromPrompt("Введите сумму расхода:")
                    if (amount === null) return true
                    if (isNaN(amount) || amount <= 0) { console.log("Число не может быть отрицательным"); return true }
                    
                    let category = prompt("Введите категорию:")
                    if (!category) { console.log("Категория не может быть пустой"); return true }
                    
                    addExpense(title, amount, category)
                    break
                }
                case "2": printAllExpenses(); break
                case "3": getTotalAmount(true); break
                case "4": {
                    let cat = prompt("Введите категорию для поиска:")
                    if (cat) getExpensesByCategory(cat)
                    break
                }
                case "5": {
                    let search = prompt("Введите текст для поиска:")
                    if (search) findExpenseByTitle(search)
                    break
                }
                case "6": {
                    let id = getNumberFromPrompt("Введите ID расхода для удаления:")
                    if (id !== null && !isNaN(id)) deleteExpenseById(id)
                    break
                }
                case "7": printCategoryStats(); break
                case "0":
                    console.log("До свидания. Все записи сохранены в консоли.")
                    return false
                default: console.log("Введите число от 0 до 7.")
            }
            return true
        }

        function startApp() {
            console.log("Запуск трекера расходов")
            let isRunning = true
            
            while (isRunning) {
                let choice = showNotificationMenu()
                if (choice === null) {
                    if (confirm("Выйти из программы?")) {
                        console.log("Программа завершена. Записи сохранены.")
                        isRunning = false
                    }
                    continue
                }
                isRunning = handleUserChoice(choice)
            }
        }

        console.log("Персональный трекер расходов v1.0")
        
        if (prompt("Запустить трекер? (да/нет)")?.toLowerCase() === "да") {
            startApp()
        } else {
            console.log("Программа выключена")
        }

        Object.assign(window, { 
            addExpense, 
            printAllExpenses, 
            getTotalAmount, 
            getExpensesByCategory, 
            findExpenseByTitle, 
            deleteExpenseById, 
            printCategoryStats, 
            expenseTracker 
        })
    </script>
</body>
</html>
